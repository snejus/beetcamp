#!/bin/zsh
# Run tests across all test files, and report what has changed in a pretty way.
# Test metadata files are stored in $TEST_FILES_DIR (./jsons) directory: those
# are JSON files that contain Bandcamp release metadata.
#
# You can use 'url2json -s <release-url>' to create such testing file for your
# release of choice.
# It extracts the relevant metadata saves it in './jsons' directory under
# the filename that resembles that release URL (where slashes are replaced by
# underscores).

setopt extendedglob nullglob
zmodload zsh/mapfile
autoload -Uz zmv

TESTS_DIR=lib_tests
SOURCE=(./beetsplug/*/^(http|__init__).py)

# Only run on the 'dev' branch (or during a rebase targeting 'dev').
([[ -d .git/rebase-merge ]] && [[ $mapfile[.git/rebase-merge/head-name] == */dev* ]]) || [[ $(git branch --show-current) == dev ]] || exit

commit=$(git show --no-patch --format='%h %s')
after=${${=commit}[1]} # Current commit short hash.
message=${commit#$after } # Current commit subject line (without the hash prefix).
print -Pn "%B$message%b: "

# Exit early if this commit doesn't modify the source files that affect tests.
if git diff --quiet HEAD~1..HEAD $SOURCE; then
  print "$after: Source code has not changed, bye"
  exit
fi

tasks=()
if [[ ! -d .git/rebase-merge ]]; then
  # During normal development, ignore 'fixup!' commits to avoid redundant runs.
  if [[ $message == fixup* ]]; then
    print "Skipping fixup commit"
    exit
  else
    print "Testing new commit"
  fi
else
  # During an interactive rebase, discover which commit is currently being
  # replayed so results can be compared/renamed appropriately.
  tasks=(${(f@)${mapfile[.git/rebase-merge/done]%$'\n'}})

  action=${tasks[-1]%% *} # e.g. 'pick', 'reword', 'edit', 'fixup', 'squash'.
  [[ $action == (fixup|squash) ]] && print "Fixup/squash: anchoring baseline to $rebase_head"
  # The most recent non-fixup/squash task (including the current one)
  # (fixup/squash tasks don't have their own results in the history, they modify previous ones).
  current_task=(${=${(M)tasks:#^(fixup |squash )*}[-1]})

  rebase_head=${current_task[2]:0:7} # Original commit hash being replayed.
  test_folder=( $TESTS_DIR/${^rebase_head}*(/) ) # Existing results for that commit.

  if [[ ${mapfile[.git/rebase-merge/git-rebase-todo]} == (fixup|squash)* ]]; then
    print "Commit $rebase_head is being rewritten, skipping"
    exit
  fi

  if (( $#test_folder )); then
    # If we're effectively at the end of the rebase (no remaining todo), run a
    # "sync" comparison against the original commit being rewritten to keep
    # results aligned to the new hash.
    if [[ ! -s .git/rebase-merge/git-rebase-todo ]] && (( ${#${(M)${tasks}:#*(edit|fixup|squash)*}} || ! ${#${(M)${tasks}:#*reword*}} )); then
      print "Current (latest) commit, testing against REBASE_HEAD $rebase_head to synchronise results"
      before=$rebase_head
    else
      # Copy existing results folders to use the new hash so history stays
      # consistent even as commits are rewritten.
      [[ $rebase_head == $after ]] || zmv -v $TESTS_DIR/'(*)'$rebase_head $TESTS_DIR/'${1}'$after

      # If the rewritten commit didn't actually change relevant sources relative
      # to its original version, skip further work.
      if git diff --quiet $rebase_head..$after $SOURCE; then
        print "No source code changes in comparison to $rebase_head"
        exit
      else
        # Otherwise, compare the rewritten commit against the previous commit.
        print "Testing updated commit $after against the last commit"
      fi
    fi
  else
    # No stored baseline for the original commit: fall back to comparing against
    # whatever baseline gets computed below.
    print "Results from base commit $rebase_head do not exist, testing against last commit: $before"
  fi
fi

# If 'before' wasn't set above, choose a reasonable baseline:
# - Prefer a recent commit hash that already has stored results in lib_tests/
#   (so comparisons are meaningful and quick).
# - Fall back to 'main' if nothing suitable is found.
(( $#before )) || {
  folders=(lib_tests/^[a-z]##(/:t)) # Result folders named by commit hash prefix.
  before=$(git log main~3..HEAD~ --format=%h $SOURCE | grep -E "^(${(j:|:)folders})" -m1)
  : ${before:=main}
}

# If the working tree is dirty in relevant files, stash temporarily so tests run
# against committed state only.
git diff --quiet $SOURCE
dirty_worktree=$?
(( dirty_worktree )) && git stash

# Run the regression harness comparing 'before' -> 'after'.
./test-lib $before $after

# Restore the user's working tree (if it was stashed above).
(( dirty_worktree )) && git stash pop --quiet
