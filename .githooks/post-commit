#!/bin/zsh
# Run tests across all test files, and report what has changed in a pretty way.
# Test metadata files are stored in $TEST_FILES_DIR (./jsons) directory: those
# are JSON files that contain Bandcamp release metadata.
#
# You can use 'url2json -s <release-url>' to create such testing file for your
# release of choice.
# It extracts the relevant metadata saves it in './jsons' directory under
# the filename that resembles that release URL (where slashes are replaced by
# underscores).

setopt extendedglob nullglob
zmodload zsh/mapfile
autoload -Uz zmv

TESTS_DIR=lib_tests

[[ -d .git/rebase-merge ]] || [[ $(git branch --show-current) == dev ]] || exit

after=$(git show --no-patch --format='%h')
if git diff --quiet HEAD~1..HEAD ./beetsplug; then
  print "$after: Source code has not changed, bye"
  exit
fi

if [[ -d .git/rebase-merge ]]; then
  results=(${(f@)${mapfile[.git/rebase-merge/done]%$'\n'}})
  current_commit=(${=results[-1]})
  action=$current_commit[1]
  rebase_head=${current_commit[2]:0:7}

  if [[ ! -s .git/rebase-merge/git-rebase-todo ]] && ( (( ${#${(M)${results}:#*(edit|fixup|squash)*}} )) || (( ! ${#${(M)${results}:#*reword*}} )) ); then
    print "Current (latest) commit, testing to synchronise results"
    # get latest commit that changed the source code
    after=$(git log -1 --format=%h ./beetsplug)
  elif [[ ! -d $TESTS_DIR/$rebase_head ]]; then
    print "Results from base commit $rebase_head do not exist, testing against last commit"
  elif [[ ! $action =~ (edit|fixup|squash) ]]; then
    print "Commit rewrite, renaming $rebase_head -> $after"
    zmv -v $TESTS_DIR/'(*)'$rebase_head $TESTS_DIR/'${1}'$after
    exit
  elif [[ "$(git range-diff --quiet $rebase_head~1..$rebase_head $after~1..$after ./beetsplug)" == *" = 1:"* ]]; then
    print "No source code changes in comparison to $rebase_head, renaming $rebase_head -> $after"
    zmv -v $TESTS_DIR/'(*)'$rebase_head $TESTS_DIR/'${1}'$after
    exit
  else
    print "Comparing against REBASE_HEAD $rebase_head"
  fi
fi

folders=(lib_tests/^[a-z]##(/:t))
pat="^(${(j:|:)folders})"
before=$(git log main..$after\^ --format=%h ./beetsplug | grep -E $pat -m1)
print "Comparing with previous commit $before"

git diff --quiet ./beetsplug
dirty_worktree=$?
(( dirty_worktree )) && git stash
./test_lib $before $after
(( dirty_worktree )) && git stash pop --quiet
